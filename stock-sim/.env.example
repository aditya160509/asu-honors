DATABASE_URL="postgresql+psycopg://stocksim:stocksim@localhost:5432/stocksim"

# Future Lab (Section 11.7) async branch/ensemble jobs — Celery broker +
# result backend. Run a worker with:
#   celery -A apps.api.celery_app worker --loglevel=info
REDIS_URL="redis://localhost:6379/0"

# AI Financial Advisor. Leave empty to run without it -- ai_service raises
# a clear 503 (not a fake response) when a capability is called with no key
# set, everything else in the app is unaffected. Get a free key at
# https://aistudio.google.com/apikey -- put it in .env (repo root, next to
# this file) not apps/api/.env. This file is gitignored, so whatever key
# you put here never leaves your machine or gets committed.
GEMINI_API_KEY=""
AI_MODEL="gemini-3.5-flash"
